{
  "openapi": "3.1.0",
  "info": {
    "title": "Medical Desert Planner API",
    "summary": "Track 2 backend for finding high-risk healthcare gaps across India.",
    "description": "Combines trust-weighted capability evidence from 10,088 facilities with NFHS-5 district health indicators and reports uncertainty honestly.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Operations"],
        "summary": "Check backend readiness",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {"application/json": {"schema": {}}}
          }
        }
      }
    },
    "/api/capabilities": {
      "get": {
        "tags": ["Planning"],
        "summary": "List Capabilities",
        "description": "List the capability values accepted by the scoring endpoints.",
        "operationId": "list_capabilities_api_capabilities_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CapabilityList"}}}
          }
        }
      }
    },
    "/api/regions": {
      "get": {
        "tags": ["Planning"],
        "summary": "Rank Regions",
        "description": "Rank geographies by health need, care gap, and confidence in the evidence.",
        "operationId": "rank_regions_api_regions_get",
        "parameters": [
          {
            "name": "capability",
            "in": "query",
            "required": true,
            "schema": {"type": "string", "examples": ["NICU"], "title": "Capability"}
          },
          {
            "name": "level",
            "in": "query",
            "required": false,
            "schema": {"enum": ["state", "district"], "type": "string", "default": "district", "title": "Level"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "maximum": 706, "minimum": 1, "default": 50, "title": "Limit"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/RegionResult"},
                  "title": "Response Rank Regions Api Regions Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}
          }
        }
      }
    },
    "/api/facilities": {
      "get": {
        "tags": ["Evidence"],
        "summary": "Facility Evidence",
        "description": "Return the facility-level evidence behind a regional score.",
        "operationId": "facility_evidence_api_facilities_get",
        "parameters": [
          {
            "name": "capability",
            "in": "query",
            "required": true,
            "schema": {"type": "string", "examples": ["Emergency care"], "title": "Capability"}
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "State"}
          },
          {
            "name": "district",
            "in": "query",
            "required": false,
            "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "District"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "maximum": 500, "minimum": 1, "default": 100, "title": "Limit"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/FacilityEvidence"},
                  "title": "Response Facility Evidence Api Facilities Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CapabilityList": {
        "properties": {
          "capabilities": {"items": {"type": "string"}, "type": "array", "title": "Capabilities"}
        },
        "type": "object",
        "required": ["capabilities"],
        "title": "CapabilityList"
      },
      "FacilityEvidence": {
        "properties": {
          "facility_id": {"type": "string", "title": "Facility Id"},
          "name": {"type": "string", "title": "Name"},
          "state": {"type": "string", "title": "State"},
          "district": {"type": "string", "title": "District"},
          "pin": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Pin"},
          "tier": {"type": "string", "title": "Tier"},
          "trust_weight": {"type": "number", "title": "Trust Weight"},
          "knowledge": {"type": "number", "title": "Knowledge"},
          "evidence": {
            "items": {
              "prefixItems": [{"type": "string"}, {"type": "string"}],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Evidence"
          },
          "description": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Description"},
          "latitude": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Latitude"},
          "longitude": {"anyOf": [{"type": "number"}, {"type": "null"}], "title": "Longitude"},
          "source_urls": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Source Urls"}
        },
        "type": "object",
        "required": ["facility_id", "name", "state", "district", "tier", "trust_weight", "knowledge", "evidence"],
        "title": "FacilityEvidence"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RegionResult": {
        "properties": {
          "region": {"type": "string", "title": "Region"},
          "facilities": {"type": "integer", "title": "Facilities"},
          "claiming": {"type": "integer", "title": "Claiming"},
          "corroborated": {"type": "integer", "title": "Corroborated"},
          "coverage": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Coverage"},
          "knowledge": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Knowledge"},
          "health_need": {
            "anyOf": [{"type": "number", "maximum": 1.0, "minimum": 0.0}, {"type": "null"}],
            "title": "Health Need"
          },
          "priority_score": {"type": "number", "maximum": 1.0, "minimum": 0.0, "title": "Priority Score"},
          "status": {"type": "string", "title": "Status"}
        },
        "type": "object",
        "required": ["region", "facilities", "claiming", "corroborated", "coverage", "knowledge", "priority_score", "status"],
        "title": "RegionResult"
      },
      "ValidationError": {
        "properties": {
          "loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"},
          "msg": {"type": "string", "title": "Message"},
          "type": {"type": "string", "title": "Error Type"}
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
}
